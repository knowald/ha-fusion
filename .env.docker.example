# Docker Compose Environment Variables
# Copy this file to .env.docker and update the values for your setup
# Usage: docker-compose --env-file .env.docker up -d

# ==============================================================================
# Home Assistant Configuration
# ==============================================================================

# URL to your Home Assistant instance (required)
# Examples:
#   - Local: http://192.168.1.100:8123
#   - HTTPS: https://homeassistant.local:8123
#   - Docker internal: http://homeassistant:8123
HASS_URL=http://192.168.1.241:8123

# ==============================================================================
# General Settings
# ==============================================================================

# Timezone for the container (optional, defaults to UTC)
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Stockholm

# ==============================================================================
# Production Settings (docker-compose.yml)
# ==============================================================================

# Port to expose ha-fusion on the host (optional, defaults to 5050)
EXPOSED_PORT=5050

# Path to data directory for persistent storage (optional, defaults to ./data)
# This directory will store dashboard.yaml, configuration.yaml, and themes
DATA_PATH=./data

# ==============================================================================
# Development Settings (docker-compose.dev.yml)
# ==============================================================================

# Port for Vite dev server (optional, defaults to 5173)
DEV_PORT=5173
